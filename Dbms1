-- 3. Altering a Table

-- Add a new column

ALTER TABLE STUDENT
ADD EMAIL VARCHAR2(40);


-- Modify column size

ALTER TABLE STUDENT
MODIFY PHONE VARCHAR2(12);


-- Drop a column

ALTER TABLE STUDENT
DROP COLUMN EMAIL;


-- Add CHECK constraint

ALTER TABLE STUDENT
ADD CONSTRAINT chk_fee
CHECK (FEE > 0);



-- 4. Displaying Records

-- Display all columns

SELECT * FROM STUDENT;


-- Display selected columns

SELECT ROLLNO, NAME, FEE
FROM STUDENT;


-- Students with fee greater than 40000

SELECT NAME, FEE
FROM STUDENT
WHERE FEE > 40000;


-- Students from CSE department

SELECT S.NAME, D.DEPT_NAME
FROM STUDENT S
JOIN DEPARTMENT D
ON S.DEPT_ID = D.DEPT_ID
WHERE D.DEPT_NAME = 'CSE';


-- Order by Name

SELECT ROLLNO, NAME
FROM STUDENT
ORDER BY NAME;
