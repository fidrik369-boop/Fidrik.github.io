✅ 4. PROGRAM 2: AFTER INSERT TRIGGER (Logging)
✔ Fixes:
Missing : in :NEW
Sequence usage corrected
SQL
-- Create Sequence
CREATE SEQUENCE EMP_LOG_SEQ
START WITH 1
INCREMENT BY 1;

-- Trigger
CREATE OR REPLACE TRIGGER trg_emp_after_insert
AFTER INSERT ON EMPLOYEE
FOR EACH ROW
BEGIN
    INSERT INTO EMP_LOG (LOG_ID, EMP_ID, ACTION, CHANGE_DATE)
    VALUES (
        EMP_LOG_SEQ.NEXTVAL,
        :NEW.EMP_ID,
        'INSERT',
        SYSDATE
    );
END;
/
