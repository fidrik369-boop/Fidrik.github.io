<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Voter Eligibility</title>

<style>

table {
    width: 50%;
    border-collapse: collapse;
    margin: 20px 0;
}

table, th, td {
    border: 1px solid black;
}

th, td {
    padding: 10px;
    text-align: left;
}

</style>

</head>

<body>

<h2>Voter Eligibility</h2>

<script>

// Ask for voter name and age
var name = prompt("Please enter your name:");
var age = prompt("Please enter your age:");

// Convert age to number
age = parseInt(age);

// Check if age is valid
if (!isNaN(age)) {

var eligible = (age >= 18) ? "Yes" : "No";

// Create table
var table = "<table>";
table += "<tr><th>Name</th><th>Age</th><th>Eligible to Vote</th></tr>";
table += "<tr><td>" + name + "</td><td>" + age + "</td><td>" + eligible + "</td></tr>";
table += "</table>";

// Display table
document.body.innerHTML += table;

} else {

alert("Please enter a valid age.");

}

</script>

</body>

</html>
